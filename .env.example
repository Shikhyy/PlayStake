PACKAGE_ID=0xa8111bccb58757c9ef3d880e0667b53576648e6f5b3f9286a817e39cb34e3cc9
TEST_PLAYER_KEY=your_player_private_key_hex
TEST_SPECTATOR_KEY=your_spectator_private_key_hex
