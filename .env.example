# PlayStake - Environment Variables Template
# Copy this file to .env in the respective directories and fill in values

# ─────────────────────────────────────────────────────────────────
# ORACLE RELAY (copy to oracle-relay/.env)
# ─────────────────────────────────────────────────────────────────
PACKAGE_ID=0xa8111bccb58757c9ef3d880e0667b53576648e6f5b3f9286a817e39cb34e3cc9
ORACLE_CAP_ID=0x797af785ba04d3de243eb2e8e9d80a5f6c3eb71f19360b3c0fdedba11b105de4
ORACLE_PRIVATE_KEY=your_oracle_private_key_hex
RPC_URL=https://rpc-testnet.onelabs.cc:443
WS_PORT=3001

# ─────────────────────────────────────────────────────────────────
# FRONTEND (copy to frontend/.env)
# ─────────────────────────────────────────────────────────────────
VITE_RPC_URL=https://rpc-testnet.onelabs.cc:443
VITE_WS_URL=ws://localhost:3001
VITE_PACKAGE_ID=0xa8111bccb58757c9ef3d880e0667b53576648e6f5b3f9286a817e39cb34e3cc9
VITE_ORACLE_CAP_ID=0x797af785ba04d3de243eb2e8e9d80a5f6c3eb71f19360b3c0fdedba11b105de4

# ─────────────────────────────────────────────────────────────────
# E2E TESTS (copy to e2e/.env)
